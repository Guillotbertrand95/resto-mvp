generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  unit           String
  currentStock   Float    @default(0)
  alertThreshold Float    @default(0)
  averagePrice   Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}